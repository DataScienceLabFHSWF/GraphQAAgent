# .env.example — copy to .env and adjust for your environment
#
# Used by: docker compose -f docker-compose.backend.yml up -d --build
# Also used by: python scripts/run_qa.py (local dev)

# ── Ports (docker-compose.backend.yml) ───────────────────────────────
KGRAG_API_PORT=8000
KGRAG_FRONTEND_PORT=8501
KGRAG_API_WORKERS=1

# ── Neo4j ────────────────────────────────────────────────────────────
KGRAG_NEO4J__URI=bolt://localhost:7687
KGRAG_NEO4J__USER=neo4j
KGRAG_NEO4J__PASSWORD=password
KGRAG_NEO4J__DATABASE=neo4j

# ── Qdrant ───────────────────────────────────────────────────────────
KGRAG_QDRANT__URL=http://localhost:6333
KGRAG_QDRANT__COLLECTION_NAME=kgbuilder

# ── Fuseki / SPARQL ──────────────────────────────────────────────────
KGRAG_FUSEKI__URL=http://localhost:3030
KGRAG_FUSEKI__DATASET=ontology

# ── Ollama ───────────────────────────────────────────────────────────
# Use port 11434 for system Ollama, or 18136 for kgrag-ollama container
KGRAG_OLLAMA__BASE_URL=http://localhost:11434
KGRAG_OLLAMA__GENERATION_MODEL=qwen3:8b
KGRAG_OLLAMA__EMBEDDING_MODEL=qwen3-embedding:latest
KGRAG_OLLAMA__TEMPERATURE=0.3
KGRAG_OLLAMA__MAX_TOKENS=4096

# ── Retrieval ────────────────────────────────────────────────────────
KGRAG_RETRIEVAL__VECTOR_TOP_K=10
KGRAG_RETRIEVAL__GRAPH_MAX_HOPS=2
KGRAG_RETRIEVAL__GRAPH_MAX_NODES=50

# ── CORS (comma-separated, for gaia-tt frontend) ────────────────────
KGRAG_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ──────────────────────────────────────────────────────────
KGRAG_LOG_LEVEL=INFO
