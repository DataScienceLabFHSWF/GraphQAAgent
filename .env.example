# GraphQAAgent – Environment Variables
# Copy this file to `.env` and adjust for your setup.
#
# STANDALONE: `docker compose up -d` spins up all infra.
# BACKEND:    `docker compose -f docker-compose.backend.yml up -d`
#             connects to existing infra.
# PLATFORM:   env vars are overridden by KGPlatform's docker-compose.yml.

# ── Ports ────────────────────────────────────────────────────────────
KGRAG_API_PORT=8002
KGRAG_FRONTEND_PORT=8501
KGRAG_API_WORKERS=1

# ── Neo4j ────────────────────────────────────────────────────────────
# For local dev (no Docker): bolt://localhost:7687
# Standalone compose resolves these via Docker service names.
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
KGRAG_NEO4J__DATABASE=neo4j

# ── Qdrant ───────────────────────────────────────────────────────────
KGRAG_QDRANT__COLLECTION_NAME=kgbuilder

# ── Fuseki / SPARQL ──────────────────────────────────────────────────
KGRAG_FUSEKI__DATASET=kgbuilder
FUSEKI_ADMIN_PASSWORD=admin

# ── Ollama ───────────────────────────────────────────────────────────
# Models are pulled automatically on `docker compose up`.
KGRAG_OLLAMA__GENERATION_MODEL=qwen3:8b
KGRAG_OLLAMA__EMBEDDING_MODEL=qwen3-embedding:latest
KGRAG_OLLAMA__TEMPERATURE=0.3
KGRAG_OLLAMA__MAX_TOKENS=4096
# Host port for Ollama (standalone only)
OLLAMA_PORT=11436

# ── CORS ─────────────────────────────────────────────────────────────
KGRAG_CORS_ORIGINS=http://localhost:8501

# ── Logging ──────────────────────────────────────────────────────────
KGRAG_LOG_LEVEL=INFO
